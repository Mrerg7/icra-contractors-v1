---
import MainLayout from '../layouts/MainLayout.astro';

const contactEmail = "sales@desertrich.com";
const subjectLine = "Acquisition Inquiry — icra.contractors";
const mailtoLink = `mailto:${contactEmail}?subject=${encodeURIComponent(subjectLine)}`;

const marketStats = [
  { value: "$30B+", label: "Annual U.S. hospital & clinic construction spend", detail: "Ongoing projects create continuous demand for qualified ICRA contractors who can work safely in occupied healthcare environments.", icon: "hospital" },
  { value: "Major Pain Point", label: "Finding vetted ICRA contractors is difficult", detail: "Hospitals and general contractors frequently report challenges in identifying reliable contractors with genuine ICRA training and field experience.", icon: "search" },
  { value: "Clear Opportunity", label: "A trusted network has strong value", detail: "A vetted network or platform of ICRA-trained contractors can command premium positioning and recurring value for both contractors and project owners.", icon: "trophy" },
];

const brandPillars = [
  { title: "Vetted Contractor Network", desc: "A trusted network of ICRA-trained contractors and crews that hospitals and general contractors can confidently engage for healthcare projects.", icon: "users" },
  { title: "Directory & Matching Platform", desc: "A searchable directory or matching platform that helps project owners quickly find qualified ICRA contractors by location, trade, certification level, and project experience.", icon: "search" },
  { title: "Training & Certification Standards", desc: "Establish and maintain clear training and certification standards so project owners know exactly what level of ICRA expertise they are getting.", icon: "shield" },
  { title: "Trust & Risk Reduction", desc: "By creating a vetted network with clear standards, the brand reduces risk for hospitals and GCs while giving qualified contractors better access to high-value healthcare work.", icon: "handshake" },
];

const domainValues = [
  { title: ".contractors TLD Advantage", desc: "The .contractors extension is highly descriptive and instantly communicates a network, directory, or platform of multiple contractors. It feels modern, relevant, and purpose-built for this niche.", icon: "globe" },
  { title: "Category Leadership Potential", desc: "The name positions you as the central brand for ICRA contractors — whether as a network, directory, matching platform, or standards organization.", icon: "trophy" },
  { title: "Memorable & Descriptive", desc: "Short, clear, and easy to understand. Performs exceptionally well for a platform website, marketing materials, and when explaining the business model to contractors and project owners.", icon: "link" },
  { title: "Strong Search & SEO Potential", desc: "Excellent alignment with searches such as \"ICRA contractors\", \"healthcare construction contractors\", \"ICRA trained contractors\", and related high-intent B2B terms.", icon: "search" },
  { title: "Scalable Business Models", desc: "The brand supports multiple revenue models: contractor directory, matching platform, certification program, training network, or lead generation service.", icon: "refresh" },
  { title: "Future-Proof & Evergreen", desc: "Healthcare construction will always need qualified ICRA contractors. This brand has lasting relevance as the go-to network or platform in the space.", icon: "rocket" },
];

const businessModels = [
  { title: "Vetted ICRA Contractor Network", desc: "Build and brand a national or regional network of trained ICRA contractors that hospitals and GCs can confidently engage.", icon: "users" },
  { title: "Directory & Matching Platform", desc: "Create a searchable directory or intelligent matching platform that connects projects with qualified ICRA contractors by location, trade, and certification level.", icon: "search" },
  { title: "Training & Certification Program", desc: "Establish training standards and a certification program that contractors can earn and project owners can trust.", icon: "shield" },
  { title: "Lead Generation & Brokerage", desc: "Generate and broker leads for ICRA-trained contractors while providing project owners with vetted options and reduced risk.", icon: "handshake" },
];

const buyerProfiles = [
  { title: "Network & Platform Builders", desc: "Create a vetted network or matching platform that connects healthcare projects with qualified ICRA contractors.", icon: "users" },
  { title: "Directory & Marketplace Founders", desc: "Build the go-to directory or marketplace for finding and engaging ICRA-trained contractors.", icon: "search" },
  { title: "Training & Certification Organizations", desc: "Establish training standards and a certification program under a clear, category-owning brand.", icon: "shield" },
  { title: "Lead Generation & Brokerage Businesses", desc: "Create a lead generation or brokerage service that connects project owners with vetted ICRA contractors.", icon: "handshake" },
  { title: "Industry Standards Organizations", desc: "Position your group as the central standards and best-practice body for ICRA contractors.", icon: "globe" },
  { title: "Strategic Investors & Acquirers", desc: "Acquire a highly descriptive, relevant .contractors domain with clear commercial application in a growing regulated niche.", icon: "building" },
];
---

<MainLayout>
  <!-- ============================================ -->
  <!-- NAVBAR                                       -->
  <!-- ============================================ -->
  <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
    <div class="max-w-screen-2xl mx-auto">
      <div class="px-8 py-5 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <!-- Logo -->
          <div class="flex items-center gap-x-2.5">
            <div class="w-9 h-9 bg-icra-teal rounded-2xl flex items-center justify-center shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <span class="font-semibold tracking-tighter text-3xl">icra</span>
              <span class="text-icra-teal font-semibold text-3xl">.contractors</span>
            </div>
          </div>
          <div class="premium-badge flex items-center gap-x-1.5 ml-1">
            <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="font-semibold tracking-[0.5px] text-[10px]">PREMIUM</span>
          </div>
        </div>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
          <a href="#opportunity" class="text-slate-600 hover:text-slate-900 transition-colors">Opportunity</a>
          <a href="#brand" class="text-slate-600 hover:text-slate-900 transition-colors">The Brand</a>
          <a href="#why-domain" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
          <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">Acquire</a>
        </div>

        <div class="flex items-center gap-x-3">
          <a href={mailtoLink}
             class="hidden md:block px-5 py-2.5 text-sm font-semibold bg-white border border-slate-300 hover:border-slate-400 text-slate-700 rounded-3xl transition-all active:scale-[0.985]">
            Make an Offer
          </a>
          <a href={mailtoLink}
             class="px-6 py-2.5 text-sm font-semibold bg-icra-teal hover:bg-icra-deep text-white rounded-3xl transition-all active:scale-[0.985] shadow-sm flex items-center gap-x-2">
            <span>Inquire Now</span>
          </a>

          <!-- Mobile menu toggle -->
          <button class="md:hidden w-10 h-10 flex items-center justify-center text-slate-600" id="mobile-menu-btn">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200 px-6 py-4">
      <div class="flex flex-col gap-y-3 text-sm font-medium">
        <a href="#opportunity" class="py-1.5 text-slate-700">Opportunity</a>
        <a href="#brand" class="py-1.5 text-slate-700">The Brand</a>
        <a href="#why-domain" class="py-1.5 text-slate-700">Why This Domain</a>
        <a href="#acquire" class="py-1.5 text-slate-700">Acquire</a>
        <div class="pt-3 border-t">
          <a href={mailtoLink}
             class="block w-full py-3 text-center text-sm font-semibold bg-icra-teal text-white rounded-3xl">Inquire Now</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <header class="healthcare-gradient text-white">
    <div class="max-w-screen-2xl mx-auto px-8 pt-16 pb-20 md:pt-20 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-3xl mb-6 border border-white/20">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse-slow"></div>
          <span class="text-sm font-medium tracking-wide">EXCLUSIVELY AVAILABLE</span>
        </div>

        <h1 class="text-6xl md:text-7xl leading-[1.05] tracking-tighter font-semibold mb-4">
          icra.contractors
        </h1>

        <p class="max-w-3xl text-2xl md:text-3xl text-teal-100 tracking-tight mb-3">
          The brand for ICRA Contractors.
        </p>

        <p class="max-w-2xl text-lg text-teal-200/90 mb-9">
          Own the powerful .contractors domain that positions you as the central hub, network, or platform
          for specialized Infection Control Risk Assessment contractors in healthcare construction.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={mailtoLink}
             class="group inline-flex items-center justify-center gap-x-3 px-8 py-4 bg-white text-teal-700 font-semibold text-lg rounded-3xl hover:bg-teal-50 active:bg-white transition-all shadow-xl shadow-black/10">
            <span>Secure This Domain</span>
            <svg class="w-5 h-5 group-active:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>

          <a href="#opportunity"
             class="inline-flex items-center justify-center gap-x-2 px-7 py-4 border border-white/30 hover:bg-white/10 text-white font-medium rounded-3xl transition-all text-lg">
            <span>Explore the Opportunity</span>
          </a>
        </div>

        <div class="mt-8 flex items-center gap-x-6 text-sm">
          <div class="flex items-center -space-x-1">
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
          </div>
          <span class="text-teal-200 text-sm">The network brand connecting hospitals & GCs with trained ICRA contractors</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ============================================ -->
  <!-- TRUST / STATS BAR                            -->
  <!-- ============================================ -->
  <div class="border-b border-slate-200 bg-white">
    <div class="max-w-screen-2xl mx-auto px-8 py-5">
      <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-4 text-center md:text-left">
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">.contractors TLD — instantly communicates network or platform</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">Hospitals & GCs struggle to find reliable ICRA-trained contractors</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">A vetted network of ICRA contractors has clear market demand</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- THE OPPORTUNITY                              -->
  <!-- ============================================ -->
  <section id="opportunity" class="max-w-screen-2xl mx-auto px-8 pt-16 pb-12">
    <div class="max-w-3xl mb-10">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE MARKET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">Finding reliable ICRA-trained contractors remains a major pain point for hospitals and GCs.</h2>
      <p class="mt-4 text-lg text-slate-600">Healthcare construction projects require contractors who truly understand infection control. Yet most general contractors and health systems struggle to identify and vet reliable ICRA-trained crews and specialty contractors. This creates a clear opportunity for a trusted network, directory, or platform that connects projects with qualified ICRA contractors — reducing risk, improving compliance, and streamlining the bidding process.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {marketStats.map((stat) => (
        <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
          <div class="flex justify-between items-start">
            <div>
              <div class="text-5xl font-semibold tracking-tighter text-slate-900">{stat.value}</div>
              <div class="text-icra-teal font-medium mt-1">{stat.label}</div>
            </div>
            <div class="text-icra-teal-pale">
              {stat.icon === 'hospital' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>}
              {stat.icon === 'search' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {stat.icon === 'trophy' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>}
            </div>
          </div>
          <p class="text-sm text-slate-500 mt-5 leading-snug">{stat.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE BRAND                                    -->
  <!-- ============================================ -->
  <section id="brand" class="bg-white border-y border-slate-200 py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-3xl mb-10">
        <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE ICRA CONTRACTORS BRAND</div>
        <h2 class="text-4xl font-bold tracking-tighter leading-tight">What icra.contractors represents.</h2>
        <p class="mt-4 text-lg text-slate-600">This is the brand for the network, directory, or platform that connects healthcare projects with qualified, trained ICRA contractors — creating trust, reducing risk, and streamlining the process of finding the right crews for infection-sensitive construction work.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {brandPillars.map((pillar) => (
          <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
            <div class="w-11 h-11 flex items-center justify-center bg-icra-teal-pale text-icra-teal rounded-2xl mb-5">
              {pillar.icon === 'users' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>}
              {pillar.icon === 'search' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {pillar.icon === 'shield' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
              {pillar.icon === 'handshake' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
            </div>
            <h4 class="font-semibold text-lg tracking-tight mb-2">{pillar.title}</h4>
            <p class="text-sm text-slate-600 leading-relaxed">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY THIS DOMAIN                              -->
  <!-- ============================================ -->
  <section id="why-domain" class="max-w-screen-2xl mx-auto px-8 py-16">
    <div class="max-w-3xl mb-9">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE STRATEGIC ASSET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">Why icra.contractors is a powerful brand.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {domainValues.map((item) => (
        <div class="value-prop bg-white border border-slate-200 p-7 rounded-3xl modern-card">
          <div class="flex items-center gap-x-3 mb-4">
            <div class="text-icra-teal">
              {item.icon === 'globe' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>}
              {item.icon === 'trophy' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>}
              {item.icon === 'link' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>}
              {item.icon === 'search' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {item.icon === 'refresh' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>}
              {item.icon === 'rocket' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
            </div>
            <h4 class="font-semibold text-xl tracking-tight">{item.title}</h4>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BUSINESS MODELS (dark)                       -->
  <!-- ============================================ -->
  <section class="bg-slate-900 text-white py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-2xl mb-9">
        <div class="text-teal-400 text-xs tracking-[2px] font-semibold mb-2">BUILD THE NETWORK OR PLATFORM</div>
        <h2 class="text-4xl tracking-tighter font-semibold">High-potential ways to activate icra.contractors.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {businessModels.map((model) => (
          <div class="bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-3xl transition-colors">
            <div class="text-teal-400 mb-4">
              {model.icon === 'users' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>}
              {model.icon === 'search' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {model.icon === 'shield' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
